# Configuration FrankenPHP pour HTTP uniquement
{
	{$CADDY_GLOBAL_OPTIONS}
	auto_https off
	servers {
		protocols h1
	}

	frankenphp {
		{$FRANKENPHP_CONFIG}
	}


}

{$SERVER_NAME:localhost}:{$SERVER_PORT:80} {
	root public/
	encode zstd br gzip

	log error {
		output stdout
		format json {
			time_format iso8601
			message_key request.uri
			level_key ""
			time_key timestamp
		}
	}

	 php_server {
       try_files {path} index.php
       file_server off
       resolve_root_symlink false

    }
}
